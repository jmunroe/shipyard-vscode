{
  "name": "shipyard-vscode",
  "displayName": "Shipyard for VS Code",
  "description": "Visualize your Shipyard sprint, backlog, and spec in the VS Code sidebar.",
  "version": "0.2.1",
  "publisher": "earthdata",
  "license": "MIT",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#0E639C",
    "theme": "dark"
  },
  "author": {
    "name": "James Munroe"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jmunroe/shipyard-vscode.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "shipyard",
    "agile",
    "sprint",
    "backlog",
    "claude-code"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "workspaceContains:**/.shipyard"
  ],
  "contributes": {
    "configuration": {
      "title": "Shipyard",
      "properties": {
        "shipyard.autoRunCommands": {
          "type": "boolean",
          "default": false,
          "description": "When enabled, Shipyard slash commands sent to the terminal are executed immediately. When disabled (default), they are typed for you to review and run."
        },
        "shipyard.terminalTarget": {
          "type": "string",
          "enum": ["dedicated", "active"],
          "enumDescriptions": [
            "Send to a dedicated \"Shipyard\" terminal (created if needed). Predictable — never hijacks another focused terminal. Run Claude Code in this terminal.",
            "Send to the currently active terminal (a new one is created if none is open). Convenient when Claude Code is focused, but commands can land in an unrelated shell."
          ],
          "default": "dedicated",
          "description": "Which terminal Shipyard sends slash commands to. 'dedicated' (default) keeps a predictable \"Shipyard\" terminal; 'active' uses whatever terminal is focused."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "shipyard",
          "title": "Shipyard",
          "icon": "media/shipyard.svg"
        }
      ]
    },
    "views": {
      "shipyard": [
        {
          "id": "shipyard.sprint",
          "name": "Sprint"
        },
        {
          "id": "shipyard.backlog",
          "name": "Backlog"
        },
        {
          "id": "shipyard.spec",
          "name": "Spec"
        },
        {
          "id": "shipyard.bugs",
          "name": "Bugs"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "shipyard.sprint",
        "contents": "No Shipyard project found in this workspace.\nShipyard stores its data in a .shipyard/ folder at the repo root.\n[Learn about Shipyard](https://github.com/Acendas/shipyard)"
      }
    ],
    "commands": [
      {
        "command": "shipyard.refresh",
        "title": "Shipyard: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "shipyard.openConfig",
        "title": "Shipyard: Open Project Config",
        "icon": "$(gear)"
      },
      {
        "command": "shipyard.openDashboard",
        "title": "Shipyard: Open Dashboard",
        "icon": "$(dashboard)"
      },
      {
        "command": "shipyard.sendStatus",
        "title": "Shipyard: Status",
        "icon": "$(pulse)"
      },
      {
        "command": "shipyard.sendSprint",
        "title": "Shipyard: Sprint",
        "icon": "$(rocket)"
      },
      {
        "command": "shipyard.sendBacklog",
        "title": "Shipyard: Backlog",
        "icon": "$(list-ordered)"
      },
      {
        "command": "shipyard.sendExecute",
        "title": "Shipyard: Execute",
        "icon": "$(play)"
      },
      {
        "command": "shipyard.sendReview",
        "title": "Shipyard: Review",
        "icon": "$(checklist)"
      },
      {
        "command": "shipyard.discussItem",
        "title": "Discuss in Shipyard"
      },
      {
        "command": "shipyard.debugBug",
        "title": "Debug in Shipyard"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "shipyard.refresh",
          "when": "view == shipyard.sprint || view == shipyard.backlog || view == shipyard.spec || view == shipyard.bugs",
          "group": "navigation"
        },
        {
          "command": "shipyard.openConfig",
          "when": "view == shipyard.sprint",
          "group": "navigation"
        },
        {
          "command": "shipyard.openDashboard",
          "when": "view == shipyard.sprint || view == shipyard.backlog || view == shipyard.spec || view == shipyard.bugs",
          "group": "navigation"
        },
        {
          "command": "shipyard.sendStatus",
          "when": "(view == shipyard.sprint || view == shipyard.backlog || view == shipyard.spec || view == shipyard.bugs) && shipyard.hasProject",
          "group": "navigation"
        },
        {
          "command": "shipyard.sendSprint",
          "when": "view == shipyard.sprint && shipyard.hasProject",
          "group": "navigation"
        },
        {
          "command": "shipyard.sendExecute",
          "when": "view == shipyard.sprint && shipyard.hasProject",
          "group": "navigation"
        },
        {
          "command": "shipyard.sendReview",
          "when": "view == shipyard.sprint && shipyard.hasProject",
          "group": "navigation"
        },
        {
          "command": "shipyard.sendBacklog",
          "when": "view == shipyard.backlog && shipyard.hasProject",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "shipyard.discussItem",
          "when": "viewItem == feature || viewItem == idea || viewItem == epic",
          "group": "shipyard"
        },
        {
          "command": "shipyard.debugBug",
          "when": "viewItem == bug",
          "group": "shipyard"
        }
      ]
    }
  },
  "scripts": {
    "compile": "node esbuild.mjs",
    "icon": "node scripts/render-icon.mjs",
    "watch": "node esbuild.mjs --watch",
    "package": "node esbuild.mjs --production && vsce package",
    "typecheck": "tsc --noEmit",
    "smoke": "esbuild test/smoke.ts --bundle --platform=node --format=cjs --outfile=node_modules/.cache/sy-smoke.cjs && node node_modules/.cache/sy-smoke.cjs",
    "vscode:prepublish": "node esbuild.mjs --production"
  },
  "dependencies": {
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.23.0",
    "typescript": "^5.5.0"
  }
}
